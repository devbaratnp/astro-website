RewriteEngine On
RewriteBase /

# Redirect to canonical: https://www.astroshreehari.com
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} !^www\. [NC]
RewriteRule ^ https://www.astroshreehari.com%{REQUEST_URI} [L,R=301]

# Serve React SPA for root URL
RewriteRule ^$ index.html [L]

# Allow PHP backend API
RewriteRule ^backend/ - [L]

# Allow admin panel
RewriteRule ^admin/ - [L]

# Allow existing files and directories
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# SPA: route everything else to React index.html
RewriteRule ^ index.html [L]

# Security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Permissions-Policy "geolocation=(), camera=(), microphone=()"
</IfModule>

# Security
<FilesMatch "\.(env|sql|md|log)$">
    Require all denied
</FilesMatch>

# Cache static assets
<FilesMatch "\.(js|css|png|jpg|jpeg|webp|svg|woff2?)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>
