RewriteEngine On

# Redirect to canonical production URL (skip for local/dev)
RewriteCond %{HTTP_HOST} !^localhost(:[0-9]+)?$ [NC]
RewriteCond %{HTTP_HOST} !^127\.0\.0\.1(:[0-9]+)?$ [NC]
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} !^www\. [NC]
RewriteRule ^ https://www.astroshreehari.com%{REQUEST_URI} [L,R=301]

# Allow files and directories
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Serve PHP backend API
RewriteRule ^backend/ - [L]

# Webhook
RewriteRule ^webhook\.php$ - [L]

# Public page routes
RewriteRule ^$ index.php [L]
RewriteRule ^about/?$ about.php [L,QSA]
RewriteRule ^services/?$ services.php [L,QSA]
RewriteRule ^appointment/?$ appointment.php [L,QSA]
RewriteRule ^contact/?$ contact.php [L,QSA]
RewriteRule ^kundali/?$ kundali.php [L,QSA]
RewriteRule ^pooja/?$ pooja.php [L,QSA]
RewriteRule ^panchang/?$ panchang.php [L,QSA]
RewriteRule ^payment/?$ payment.php [L,QSA]
RewriteRule ^blog/?$ blog.php [L,QSA]
RewriteRule ^article/([^/]+)/?$ article.php?slug=$1 [L,QSA]
RewriteRule ^events/?$ events.php [L,QSA]
RewriteRule ^gallery/?$ gallery.php [L,QSA]
RewriteRule ^muhurta/?$ muhurta.php [L,QSA]
RewriteRule ^store/?$ store.php [L,QSA]

# Admin route
RewriteRule ^admin/?$ admin/index.php [L]

# 404 for everything else
RewriteRule .* - [R=404,L]

# Security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Permissions-Policy "geolocation=(), camera=(), microphone=()"
    Header set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    Header set Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://fonts.googleapis.com; frame-src https://meet.jit.si https://www.google.com; base-uri 'self'; form-action 'self'"
</IfModule>

# Security: deny access to sensitive files
<FilesMatch "\.(env|sql|md|log|yml|json)$">
    Require all denied
</FilesMatch>

# Cache static assets
<FilesMatch "\.(js|css|png|jpg|jpeg|webp|svg|woff2?)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>
